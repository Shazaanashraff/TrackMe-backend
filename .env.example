# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# ---- Server ----
PORT=5000
# NODE_ENV=development

# ---- Database ----
# Local Docker Mongo (see README/setup): mongodb://localhost:27017/trackme
MONGODB_URI=mongodb://localhost:27017/trackme

# ---- Auth / JWT ----
# Use long, random strings. These dev defaults are NOT safe for a shared deployment.
JWT_SECRET=dev-jwt-secret-change-me
JWT_EXPIRES_IN=15m
# Access-token lifetime. 7d in local dev keeps the live socket from dropping
# mid-session; use a short value (e.g. 15m) in production.
ACCESS_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-me
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS allow-list (comma-separated origins). '*' is fine for local dev.
CLIENT_ORIGINS=*

# ---- Google (server-side proxy key) ----
# Single key used by /api/places/* and /api/transit/* — Places autocomplete/details,
# Routes API transit planning, and reverse Geocoding for the drag-pin.
# SERVER-SIDE ONLY — never ship this to the client.
# Enable on the Google Cloud project (billing required):
#   - Places API (New)
#   - Routes API
#   - Geocoding API   (optional: drag-pin reverse lookup; falls back to free OSM if absent/disabled)
GOOGLE_PLACES_KEY=your-google-server-key

# Server-side key used to snap driver-recorded custom routes to roads
# (POST /api/driver/custom-routes/record). Enable "Roads API" on the same
# Google Cloud project. Optional: falls back to GOOGLE_ROUTES_KEY, then
# GOOGLE_PLACES_KEY, then to the raw (unsnapped) breadcrumb if none are set.
GOOGLE_ROADS_KEY=

# Off-route detection thresholds for custom (school/work shuttle) routes.
# A journey is flagged only when BOTH are exceeded (sustained deviation,
# not one-off GPS noise). Tune with real GPS data. Optional: default 150/0.35.
CUSTOM_ROUTE_THRESHOLD_METERS=150
CUSTOM_ROUTE_THRESHOLD_FRACTION=0.35

# ---- Private Routes (room-key / PIN) ----
# 32-byte key (hex or base64) for AES-256-GCM encryption of room-key codes so the
# owning manager can reveal/copy them. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ROOM_KEY_SECRET=dev-room-key-secret-change-me-0123456789ab
# HMAC key for the deterministic room-key lookup hash (manual-entry lookup + uniqueness).
ROOM_KEY_PEPPER=dev-room-key-pepper-change-me
# Wrong-code attempts allowed before a (user, route) lockout with escalating backoff.
ROOM_KEY_MAX_ATTEMPTS=5

# ---- Optional ----
# Google OAuth client ID for verifying Google sign-in (leave blank to disable).
GOOGLE_CLIENT_ID=
# Resend transactional email (verification mails). Blank disables outbound email;
# locally, create users pre-verified instead (see setup notes).
RESEND_API_KEY=
RESEND_FROM=
# Set to 1 for verbose Socket.IO logs.
SOCKET_DEBUG=
